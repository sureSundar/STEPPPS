{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/event.schema.json",
  "title": "Event Entity",
  "description": "An event - birth, operation, consent, contract violation, shutdown, audit",
  "type": "object",
  "required": ["kind", "id", "event_type", "timestamp"],
  "properties": {
    "kind": { "const": "event" },
    "id": { "type": "string", "pattern": "^steppps://event/" },
    "event_type": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "actor": { "type": "string" },
    "subject": { "type": "string" },
    "place": { "type": "string" },
    "karma_delta": { "type": "integer" },
    "description": { "type": "string" }
  }
}
