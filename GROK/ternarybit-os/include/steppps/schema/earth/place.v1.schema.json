{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/place.schema.json",
  "title": "Place Entity",
  "description": "A place - home, temple, school, hospital, office, village, city",
  "type": "object",
  "required": ["kind", "id", "name", "place_type"],
  "properties": {
    "kind": { "const": "place" },
    "id": { "type": "string", "pattern": "^steppps://place/" },
    "name": { "type": "string", "minLength": 1 },
    "place_type": { "type": "string" },
    "sangha": { "type": "string" },
    "location": { "type": "object" },
    "created": { "type": "string", "format": "date-time" }
  }
}
