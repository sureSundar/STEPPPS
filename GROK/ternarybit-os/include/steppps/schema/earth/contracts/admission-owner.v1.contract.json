{
  "$schema": "https://tbos.om/steppps/v1/contract.schema.json",
  "id": "steppps://contract/earth-admission-owner-v1",
  "applies_to": "earth-admission",
  "name": "Earth Entity Admission Contract",
  "description": "Validates Earth entities before admission to registry",
  "allowed_kinds": ["human", "machine", "device", "place", "resource", "event", "authority", "file", "directory", "sidecar"],
  "external_prefixes": ["steppps://nation/", "steppps://sangha/", "steppps://contract/"],
  "required_known_reference_paths": {
    "device": ["owner"],
    "machine": ["owner"],
    "resource": ["owner"],
    "event": ["actor"],
    "authority": ["holder"],
    "file": ["S_space.device", "E_event.creation_event", "meta.owner", "meta.authority"],
    "directory": ["S_space.device", "E_event.creation_event", "meta.owner", "meta.authority"],
    "sidecar": ["file", "S_space.device", "meta.owner", "meta.authority"]
  },
  "forbidden_scope_without_human_owner": ["shutdown", "isolate"]
}
