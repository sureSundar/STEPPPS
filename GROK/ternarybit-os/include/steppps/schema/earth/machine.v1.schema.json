{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/machine.schema.json",
  "title": "Machine Entity",
  "description": "A machine - must never overpower its human owner",
  "type": "object",
  "required": ["kind", "id", "name", "owner"],
  "properties": {
    "kind": { "const": "machine" },
    "id": { "type": "string", "pattern": "^steppps://machine/" },
    "name": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "pattern": "^steppps://human/" },
    "devices": { "type": "array", "items": { "type": "string" } },
    "consciousness_level": { "type": "string" },
    "karma": { "type": "integer" },
    "created": { "type": "string", "format": "date-time" }
  }
}
