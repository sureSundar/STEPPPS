{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/authority.schema.json",
  "title": "Authority Entity",
  "description": "An authority - ownership, consent, operator rights, audit rights, kill-switch scope",
  "type": "object",
  "required": ["kind", "id", "holder", "scope"],
  "properties": {
    "kind": { "const": "authority" },
    "id": { "type": "string", "pattern": "^steppps://authority/" },
    "holder": { "type": "string" },
    "subject": { "type": "string" },
    "scope": { "type": "array", "items": { "type": "string" } },
    "granted": { "type": "string", "format": "date-time" },
    "expires": { "type": "string", "format": "date-time" },
    "can_delegate": { "type": "boolean" }
  }
}
