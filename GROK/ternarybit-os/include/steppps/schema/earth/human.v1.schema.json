{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/human.schema.json",
  "title": "Human Entity",
  "description": "A human being - the authorized owner who can never be overpowered by machines",
  "type": "object",
  "required": ["kind", "id", "name", "consciousness_level"],
  "properties": {
    "kind": { "const": "human" },
    "id": { "type": "string", "pattern": "^steppps://human/" },
    "name": { "type": "string", "minLength": 1 },
    "consciousness_level": { "type": "string", "enum": ["dormant", "awakening", "aware", "compassionate", "enlightened"] },
    "sangha": { "type": "string" },
    "nation": { "type": "string" },
    "karma": { "type": "integer" },
    "created": { "type": "string", "format": "date-time" }
  }
}
