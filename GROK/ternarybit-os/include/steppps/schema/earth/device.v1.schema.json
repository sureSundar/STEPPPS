{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/device.schema.json",
  "title": "Device Entity",
  "description": "A device - calculator, radio, sensor, battery, display, storage, network endpoint",
  "type": "object",
  "required": ["kind", "id", "name", "device_type", "owner"],
  "properties": {
    "kind": { "const": "device" },
    "id": { "type": "string", "pattern": "^steppps://device/" },
    "name": { "type": "string", "minLength": 1 },
    "device_type": { "type": "string", "enum": ["calculator", "radio", "sensor", "battery", "display", "storage", "network"] },
    "owner": { "type": "string" },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "created": { "type": "string", "format": "date-time" }
  }
}
