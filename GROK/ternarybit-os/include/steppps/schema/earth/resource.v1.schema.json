{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/include/steppps/schema/earth/resource.v1.schema.json",
  "title": "TBOS Earth Resource Template v1",
  "description": "Real Earth resource template for power, compute, storage, network, radio, water, food, and attention.",
  "type": "object",
  "additionalProperties": false,
  "required": ["template_version", "kind", "id", "resource_class", "owner"],
  "properties": {
    "template_version": { "const": "1.0" },
    "kind": { "const": "resource" },
    "id": { "$ref": "#/$defs/steppps_ref" },
    "resource_class": {
      "type": "string",
      "enum": ["power", "compute", "storage", "network", "radio_channel", "sensor_data", "water", "food", "attention", "other"]
    },
    "owner": { "$ref": "#/$defs/steppps_ref" },
    "location": { "$ref": "#/$defs/steppps_ref" },
    "capacity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string" }
      }
    },
    "sharing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shareable": { "type": "boolean" },
        "requires_consent": { "type": "boolean" },
        "contract": { "$ref": "#/$defs/steppps_ref" }
      }
    }
  },
  "$defs": {
    "steppps_ref": {
      "type": "string",
      "pattern": "^steppps://.+"
    }
  }
}
