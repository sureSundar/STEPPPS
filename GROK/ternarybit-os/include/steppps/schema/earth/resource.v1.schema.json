{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/earth/resource.schema.json",
  "title": "Resource Entity",
  "description": "A resource - power, compute, storage, network, radio channel, attention",
  "type": "object",
  "required": ["kind", "id", "name", "resource_type"],
  "properties": {
    "kind": { "const": "resource" },
    "id": { "type": "string", "pattern": "^steppps://resource/" },
    "name": { "type": "string", "minLength": 1 },
    "resource_type": { "type": "string", "enum": ["power", "compute", "storage", "network", "radio", "attention"] },
    "owner": { "type": "string" },
    "capacity": { "type": "object" },
    "status": { "type": "string" },
    "created": { "type": "string", "format": "date-time" }
  }
}
