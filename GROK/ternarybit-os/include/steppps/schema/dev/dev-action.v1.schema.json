{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/dev/dev-action.schema.json",
  "title": "Development Action",
  "description": "A TBOS development action with full STEPPPS dimensions and enterprise context",
  "type": "object",
  "required": ["kind", "id", "space", "time", "event", "psychology", "pixel", "prompt", "script"],
  "properties": {
    "kind": { "const": "dev-action" },
    "id": { "type": "string", "pattern": "^steppps://dev-action/" },
    "space": {
      "type": "object",
      "required": ["repo", "paths"],
      "properties": {
        "repo": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "time": {
      "type": "object",
      "required": ["created"],
      "properties": {
        "created": { "type": "string", "format": "date-time" }
      }
    },
    "event": {
      "type": "object",
      "required": ["action", "intent"],
      "properties": {
        "action": { "type": "string", "enum": ["create", "modify", "delete", "refactor", "fix", "test", "document"] },
        "intent": { "type": "string" }
      }
    },
    "psychology": {
      "type": "object",
      "required": ["awareness"],
      "properties": {
        "awareness": { "type": "string" },
        "karma_delta": { "type": "integer" }
      }
    },
    "pixel": {
      "type": "object",
      "required": ["display_logic"],
      "properties": {
        "display_logic": { "type": "string" }
      }
    },
    "prompt": {
      "type": "object",
      "required": ["next_genai_prompt"],
      "properties": {
        "source": { "type": "string" },
        "next_genai_prompt": { "type": "string" }
      }
    },
    "script": {
      "type": "object",
      "required": ["acts_on", "verification"],
      "properties": {
        "acts_on": { "type": "array", "items": { "type": "string", "enum": ["space", "time", "event", "psychology", "pixel", "prompt", "script"] } },
        "commands": { "type": "array", "items": { "type": "string" } },
        "verification": { "type": "array", "items": { "type": "string" } }
      }
    },
    "enterprise_context": {
      "type": "object",
      "required": ["capability", "stakeholders", "business_value", "risk", "acceptance_criteria", "operational_controls"],
      "properties": {
        "capability": { "type": "string", "minLength": 1 },
        "stakeholders": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "business_value": { "type": "string", "minLength": 1 },
        "risk": { "type": "string", "minLength": 1 },
        "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "operational_controls": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
