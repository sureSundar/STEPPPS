{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/nation-contract.schema.json",
  "title": "Nation Contract",
  "description": "Governance contract for a nation (federation of Sanghas)",
  "type": "object",
  "required": ["contract_version", "nation_id", "name", "sovereignty"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "nation_id": { "type": "string", "pattern": "^steppps://nation/" },
    "name": { "type": "string", "minLength": 1 },
    "sovereignty": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" },
        "constitution": { "type": "string" },
        "supreme_authority": { "type": "string" }
      }
    },
    "sanghas": { "type": "object" },
    "citizens": { "type": "object" },
    "foreign_relations": { "type": "object" },
    "defense": { "type": "object" }
  }
}
