{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/sangha-contract.schema.json",
  "title": "Sangha Contract",
  "description": "Community governance contract for a local Sangha",
  "type": "object",
  "required": ["contract_version", "sangha_id", "name", "governance", "membership"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "sangha_id": { "type": "string", "pattern": "^steppps://sangha/" },
    "name": { "type": "string", "minLength": 1 },
    "governance": {
      "type": "object",
      "required": ["type", "admin"],
      "properties": {
        "type": { "type": "string" },
        "admin": { "type": "string" },
        "council": { "type": "array", "items": { "type": "string" } },
        "consensus": { "type": "string" }
      }
    },
    "membership": {
      "type": "object",
      "properties": {
        "entry_requirements": { "type": "object" },
        "exit_conditions": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "rules": { "type": "object" },
    "inter_sangha": { "type": "object" },
    "ascension_path": { "type": "object" }
  }
}
