{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/package/package.schema.json",
  "title": "TBOS Package",
  "description": "A TBOS installable package as a STEPPPS entity, not a bespoke binary format. docs/TBOS_LINUX_DISTRO_ROADMAP.md, roadmap step 3: a package that isn't a real STEPPPS-describable object doesn't belong in this codebase.",
  "type": "object",
  "required": ["kind", "id", "space", "time", "event", "psychology", "pixel", "prompt", "script", "package"],
  "properties": {
    "kind": { "const": "package" },
    "id": { "type": "string", "pattern": "^steppps://package/" },
    "space": {
      "type": "object",
      "required": ["repo", "paths"],
      "properties": {
        "repo": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } }
      }
    },
    "time": {
      "type": "object",
      "required": ["created"],
      "properties": {
        "created": { "type": "string", "format": "date-time" }
      }
    },
    "event": {
      "type": "object",
      "required": ["action", "intent"],
      "properties": {
        "action": { "type": "string", "enum": ["publish", "update", "deprecate", "yank"] },
        "intent": { "type": "string" }
      }
    },
    "psychology": {
      "type": "object",
      "required": ["awareness"],
      "properties": {
        "awareness": { "type": "string" },
        "karma_delta": { "type": "integer" }
      }
    },
    "pixel": {
      "type": "object",
      "required": ["display_logic"],
      "properties": {
        "display_logic": { "type": "string" }
      }
    },
    "prompt": {
      "type": "object",
      "required": ["next_genai_prompt"],
      "properties": {
        "source": { "type": "string" },
        "next_genai_prompt": { "type": "string" }
      }
    },
    "script": {
      "type": "object",
      "required": ["acts_on", "verification"],
      "properties": {
        "acts_on": { "type": "array", "items": { "type": "string", "enum": ["space", "time", "event", "psychology", "pixel", "prompt", "script", "package"] } },
        "commands": { "type": "array", "items": { "type": "string" } },
        "verification": { "type": "array", "items": { "type": "string" } }
      }
    },
    "package": {
      "type": "object",
      "description": "Package-specific metadata. Kept deliberately minimal for v1: no dependency resolution (docs/TBOS_LINUX_DISTRO_ROADMAP.md explicitly defers it to avoid scope creep before a package manager exists to consume this format).",
      "required": ["name", "version", "provides", "depends"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "provides": {
          "type": "array",
          "minItems": 1,
          "description": "Files this package installs, as {source, dest} pairs. source is repo-relative (matches an entry in space.paths); dest is FHS-relative (e.g. usr/bin/tpkg).",
          "items": {
            "type": "object",
            "required": ["source", "dest"],
            "properties": {
              "source": { "type": "string" },
              "dest": { "type": "string" }
            }
          }
        },
        "depends": {
          "type": "array",
          "description": "Intentionally unenforced in v1 - no dependency resolver exists yet. A non-empty list here is a statement of intent only, not a guarantee.",
          "items": { "type": "string" }
        }
      }
    }
  }
}
