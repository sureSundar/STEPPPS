{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tbos.om/steppps/v1/steppps-let.schema.json",
  "title": "STEPPPS-let",
  "description": "The atomic infolet of TBOS - every entity represented in seven dimensions",
  "type": "object",
  "required": ["steppps_version", "id", "S_space", "T_time", "E_event", "P_psychology", "P_pixel", "P_prompt", "S_script"],
  "properties": {
    "steppps_version": { "const": "1.0" },
    "id": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "high": { "type": "string" },
        "low": { "type": "string" },
        "uri": { "type": "string", "pattern": "^steppps://" }
      }
    },
    "S_space": {
      "type": "object",
      "required": ["realm"],
      "properties": {
        "realm": { "type": "string", "enum": ["bhulok", "swarga", "patala"] },
        "device_fingerprint": { "type": "string" },
        "location": { "type": "object" }
      }
    },
    "T_time": {
      "type": "object",
      "required": ["created"],
      "properties": {
        "created": { "type": "string", "format": "date-time" },
        "modified": { "type": "string", "format": "date-time" },
        "birth_epoch": { "type": "integer" },
        "pranan": { "type": "object" }
      }
    },
    "E_event": {
      "type": "object",
      "properties": {
        "history": { "type": "array" },
        "dormant_samskaras": { "type": "array" }
      }
    },
    "P_psychology": {
      "type": "object",
      "required": ["consciousness_level"],
      "properties": {
        "consciousness_level": {
          "type": "string",
          "enum": ["dormant", "awakening", "aware", "compassionate", "enlightened"]
        },
        "mana_ottam": { "type": "object" },
        "karma": { "type": "object" }
      }
    },
    "P_pixel": {
      "type": "object",
      "required": ["form"],
      "properties": {
        "form": { "type": "string" },
        "representation": { "type": "object" }
      }
    },
    "P_prompt": {
      "type": "object",
      "properties": {
        "voice": { "type": "object" },
        "interface": { "type": "object" }
      }
    },
    "S_script": {
      "type": "object",
      "properties": {
        "executable_dharma": { "type": "object" },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "intents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "meta": { "type": "object" }
  }
}
